{% comment %}
  Renders loading-spinner.
  Accepts:
    - class: {string} css classes to replace the default ones (optional)

  Usage:
  {% render 'loading-spinner' %}
{% endcomment %}

<div class="{% if class %}{{ class }}{% else %}twcss-absolute twcss-left-1/2 twcss--translate-x-1/2 twcss--translate-y-1/2 twcss-items-center twcss-h-12 twcss-w-12 twcss-w-[1.8rem] twcss-absolute twcss-z-[1] loading__spinner twcss-hidden{% endif %}">
  {{ 'loading-spinner.svg' | inline_asset_content }}
</div>
