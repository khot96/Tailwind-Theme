<section class="maxsm:twcss-h-[790px] twcss-bg-[#fff] twcss-rounded-[40px]">
  <div class="twcss-max-w-[120rem] twcss-mx-auto twcss-px-[5rem] twcss-overflow-hidden twcss-relative">
    <div class="twcss-absolute twcss-inset-0 twcss-pointer-events-none">
      <div class="twcss-absolute twcss-top-1/3 twcss-left-0 twcss-right-0 twcss-border-t twcss-border-dashed twcss-border-[#e5e5e5]"></div>
      <div class="twcss-absolute twcss-top-2/3 twcss-left-0 twcss-right-0 twcss-border-t twcss-border-dashed twcss-border-[#e5e5e5]"></div>
    </div>
    <div class="twcss-relative twcss-z-[2] twcss-py-20">
      <div class="twcss-grid lg:twcss-grid-cols-2 maxsm:twcss-gap-[20px] twcss-gap-[50px] twcss-items-start">
        <div>
          <h2 class="twcss-font-satoshi twcss-font-medium maxsm:twcss-text-[20px] twcss-text-[40px] twcss-leading-[1] twcss-font-medium twcss-text-black max-lg:twcss-text-[48px] max-md:twcss-text-[36px]">
            {{ section.settings.store_title }}
          </h2>
          <div class="twcss-mt-[25px]">
            <p class="twcss-font-inter twcss-font-light twcss-text-[20px] twcss-text-black twcss-w-[255px] twcss-leading-[1.5] max-md:twcss-text-[18px]">
              {{ section.settings.address }}
            </p>
          </div>
          {% if section.settings.store_image != blank %}
          <div class="maxsm:twcss-text-[20px] twcss-mt-[40px]">
            <img
              src="{{ section.settings.store_image | image_url: width: 300 }}"
              alt=""
              class="twcss-w-[120px] twcss-h-[80px] twcss-object-cover twcss-rounded-[12px]"
            >
          </div>
          {% endif %}
          <div class="maxsm:twcss-text-[20px] twcss-mt-[35px]">
            <p class="twcss-font-inter twcss-font-light twcss-text-[18px] twcss-text-[#000]">
              {{ section.settings.copyright }}
            </p>
          </div>
        </div>
        <div class="twcss-flex maxsm:twcss-gap-[20px] twcss-gap-[81px] twcss-flex-wrap">
          <h2 class="twcss-font-satoshi twcss-font-medium maxsm:twcss-text-[30px] twcss-text-[74px] twcss-leading-[0.95] twcss-font-medium twcss-break-all twcss-text-black max-lg:twcss-text-[70px] max-md:twcss-text-[42px]">
            {{ section.settings.email }}
          </h2>
          <div class="maxsm:twcss-mt-[0px] twcss-mt-[70px] max-md:twcss-mt-[40px]">
            <div class="maxsm:twcss-bg-[transparent] twcss-bg-black twcss-rounded-full twcss-flex twcss-flex-wrap twcss-gap-[1px]">
              {% for link in section.settings.footer_menu.links %}
                <a
                  href="{{ link.url }}"
                  class="twcss-font-inter twcss-font-light maxsm:twcss-text-black twcss-text-white  twcss-px-[11px] twcss-py-[16px] twcss-text-[15px] twcss-leading-none hover:twcss-opacity-80 twcss-transition"
                >
                  {{ link.title }}
                </a>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom Footer Modern",
  "settings": [
    {
      "type": "text",
      "id": "store_title",
      "label": "Store Title",
      "default": "Our store"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "2307 Beverley Rd\nBrooklyn, New York 11226\nUnited States."
    },
    {
      "type": "image_picker",
      "id": "store_image",
      "label": "Store Image"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email",
      "default": "hello@fabriogmail.com"
    },
    {
      "type": "link_list",
      "id": "footer_menu",
      "label": "Footer Menu"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright Text",
      "default": "© 2025. Fabrio. Website designed by mdaminur."
    }
  ],
  "presets": [
    {
      "name": "Custom Footer Modern"
    }
  ]
}
{% endschema %}