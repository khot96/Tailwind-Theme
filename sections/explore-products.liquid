<section id="explore-collections-{{ section.id }}" class="twcss-border twcss-border-[#e1e1e166] twcss-rounded-[35px] twcss-py-[20px] twcss-shadow-2xl">
  <div class="twcss-max-w-[120rem] twcss-mx-auto twcss-px-[5rem]  twcss-mx-auto twcss-overflow-hidden">
    <div class="twcss-grid twcss-grid-cols-1 lg:twcss-grid-cols-[1fr_300px]">
      <div class="">
        <p class="twcss-font-inter maxsm:twcss-py-[20px] twcss-py-[50px] twcss-text-[20px] twcss-font-medium twcss-text-black">
          {{ section.settings.sub_heading }}
        </p>
        <div class="maxsm:twcss-pl-[0px] twcss-pb-[40px] twcss-pl-[30px] md:twcss-pl-[70px]">
          {% for block in section.blocks %}
            {% assign collection = block.settings.collection %}
            {% if collection %}
              <a href="{{ collection.url }}">
              <div
                class="collection-item twcss-relative max-md:twcss-pr-0 twcss-py-[28px] {% unless forloop.last %}twcss-border-b twcss-border-[#e5e5e5]{% endunless %} twcss-cursor-pointer"
                data-index="{{ forloop.index0 }}"
                {{ block.shopify_attributes }}
              >
                <div>
                  <h2
                    class="collection-title twcss-font-satoshi twcss-leading-none twcss-duration-300 md:twcss-text-[60px] max-md:twcss-text-[34px] maxsm:twcss-text-[22px]
                    {% if forloop.first %}
                      twcss-text-black twcss-font-medium
                    {% else %}
                      twcss-text-[#b7b7b7] twcss-font-medium
                    {% endif %}"
                  >
                    {{ collection.title }}
                  </h2>
                  <p
                    class="collection-description twcss-font-inter md:twcss-text-[24px] maxsm:twcss-text-[15px] twcss-text-[16px] twcss-mt-[12px] twcss-duration-300
                    {% if forloop.first %}
                      twcss-text-black
                    {% else %}
                      twcss-text-[#555]
                    {% endif %}"
                  >
                    {{ collection.description | strip_html | truncate: 120 }}
                  </p>
                </div>
                <div
                  class="collection-image twcss-absolute twcss-right-[20px] twcss-top-1/2 twcss--translate-y-1/2 max-md:twcss-static max-md:twcss-translate-y-0 max-md:twcss-mt-[25px]
                  {% unless forloop.first %}
                    twcss-opacity-0 twcss-invisible
                  {% endunless %}"
                >
                  <div class="twcss-relative twcss-w-[200px] twcss-h-[200px] maxsm:twcss-w-[100px] maxsm:twcss-h-[100px] twcss-rounded-[22px] twcss-overflow-hidden twcss-rotate-[-10deg]">

                    {% if block.settings.custom_image != blank %}
                      <img
                        src="{{ block.settings.custom_image | image_url: width: 500 }}"
                        class="twcss-w-full twcss-h-full twcss-object-cover"
                        loading="lazy"
                      >
                    {% endif %}
                    <div class="twcss-absolute twcss-top-[10px] twcss-right-[10px] twcss-w-[42px] twcss-h-[42px] twcss-rounded-full twcss-bg-black twcss-flex twcss-items-center twcss-justify-center">
                      <span class="twcss-text-white twcss-text-[18px]">↗</span>
                    </div>
                  </div>
                </div>
              </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
      <div class="twcss-relative twcss-border-l twcss-border-[#e5e5e5] twcss-flex twcss-items-end twcss-justify-center twcss-p-[30px] md:twcss-p-[40px]">
         <div class="twcss-absolute maxsm:twcss-top-[0px] maxsm:twcss-unset twcss-top-[40px] twcss-w-[500px] twcss-h-[500px] twcss-opacity-70 max-md:twcss-hidden">
            <img
              src="{{ section.settings.back_image | image_url: width: 300 }}"
              alt=""
              class="maxsm:twcss-w-[auto] maxsm:twcss-h-[auto] twcss-w-full twcss-h-full twcss-object-contain"
              loading="lazy"
            >
          </div>
        <div class="twcss-max-w-[220px] twcss-text-end">
          <h3 class="twcss-font-inter twcss-text-[21px] twcss-leading-tight twcss-font-medium twcss-text-black">
            {{ section.settings.side_title }}
          </h3>
          <p class="twcss-font-inter twcss-text-right twcss-text-[13px] twcss-leading-[1.5] twcss-text-[#777] twcss-mt-[16px]">
            {{ section.settings.side_desc }}
          </p>
          {% if section.settings.button_text != blank %}
            <a
              href="{{ section.settings.button_link }}"
              class="twcss-inline-flex twcss-items-center twcss-gap-[10px] twcss-bg-[#b6ff4d] twcss-rounded-full twcss-px-[18px] twcss-py-[10px] twcss-text-black twcss-text-[14px] twcss-font-medium twcss-mt-[24px] twcss-transition hover:twcss-scale-105"
            >
              {{ section.settings.button_text }}
              <span class="twcss-w-[24px] twcss-h-[24px] twcss-rounded-full twcss-bg-black twcss-text-white twcss-flex twcss-items-center twcss-justify-center twcss-text-[12px]">
                ↗
              </span>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Explore Products",
  "settings": [
    {
      "type": "text",
      "id": "sub_heading",
      "label": "Sub Heading",
      "default": "Explore Our Products"
    },
    {
      "type": "image_picker",
      "id": "back_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "side_title",
      "label": "Side Title",
      "default": "Find Your Perfect Fit"
    },
    {
      "type": "textarea",
      "id": "side_desc",
      "label": "Side Description",
      "default": "Discover a curated selection of timeless designs."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "limit": 10,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select Collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)",
          "info": "If empty, the collection featured image will be used."
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Explore Collections",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}

<script>
document.addEventListener("DOMContentLoaded", () => {
  const section = document.querySelector("#explore-collections-{{ section.id }}");
  if (!section) return;
  const items = section.querySelectorAll(".collection-item");
  function setActive(item) {
    items.forEach((el) => {
      const title = el.querySelector(".collection-title");
      const desc = el.querySelector(".collection-description");
      const image = el.querySelector(".collection-image");

      if(title){
        title.classList.remove(
          "twcss-text-black"
                  );
        title.classList.add("twcss-text-[#b7b7b7]");
      }

      if(desc){
        desc.classList.remove(
          "twcss-text-black"
                  );
        desc.classList.add("twcss-text-[#b7b7b7]");
      }

      if(image){
        image.classList.add(
          "twcss-opacity-0",
          "twcss-invisible"
        );
        image.classList.remove(
          "twcss-opacity-100",
          "twcss-visible"
        );
      }

    });

    const activeTitle = item.querySelector(".collection-title");
    const activeDesc = item.querySelector(".collection-description");
    const activeImage = item.querySelector(".collection-image");

    if(activeTitle){
      activeTitle.classList.remove("twcss-text-[#b7b7b7]");
      activeTitle.classList.add(
        "twcss-text-black"
              );
    }

    if(activeDesc){
      activeDesc.classList.remove("twcss-text-[#b7b7b7]");
      activeDesc.classList.add(
        "twcss-text-black"
              );
    }

    if(activeImage){
      activeImage.classList.remove(
        "twcss-opacity-0",
        "twcss-invisible"
      );
      activeImage.classList.add(
        "twcss-opacity-100",
        "twcss-visible"
      );
    }

  }

  if(items.length){
    setActive(items[0]);
  }

  items.forEach((item)=>{

    item.addEventListener("mouseenter",()=>{
      setActive(item);
    });

    item.addEventListener("focus",()=>{
      setActive(item);
    });

  });

});
</script>